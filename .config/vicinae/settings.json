{
   "$schema": "https://vicinae.com/schemas/config.json",
   "font": {
      "normal": {
         "family": "Liberation Mono"
      }
   },
   "theme": {
      "dark": {
         "name": "catppuccin-mocha",
         "icon_theme": "Breeze Dark"
      }
   },
   "providers": {
      "applications": {
         "preferences": {
            "paths": [
               "/home/tina/.local/share/applications",
               "/nix/store/9811w5pyniyy5h1nypm6c9vbsx0wk3rn-vicinae-0.18.3/share/applications",
               "/nix/store/mb21ms8w67f16j4nxdsrzk7ivf8d20yy-cups-2.4.16/share/applications",
               "/run/current-system/sw/share/applications"
            ]
         },
         "entrypoints": {
            "calc": {
               "enabled": false
            }
         }
      },
      "clipboard": {
         "preferences": {
            "encryption": true,
            "eraseOnStartup": true
         },
         "entrypoints": {
            "history": {
               "preferences": {
                  "defaultAction": "copy"
               }
            }
         }
      },
      "core": {
